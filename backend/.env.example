# ===========================================
# Autonomous AI Research Agent — Environment
# ===========================================

# LLM Provider (default: groq)
# Options: groq, openai, ollama
LLM_PROVIDER=groq

# Groq API Key (free at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Groq Model
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI API Key (optional, if using openai provider)
OPENAI_API_KEY=

# OpenAI Model
OPENAI_MODEL=gpt-4o-mini

# Ollama Base URL (optional, if using ollama provider)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama Model
OLLAMA_MODEL=llama3.1

# Embedding Provider (default: local using sentence-transformers, free)
# Options: local, openai
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Search Provider (default: duckduckgo, free)
# Options: duckduckgo, serpapi
SEARCH_PROVIDER=duckduckgo
SERPAPI_KEY=

# Database
DATABASE_URL=sqlite+aiosqlite:///./research.db

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT=10/minute

# Max papers to fetch per research task
MAX_PAPERS=5
